---
interface Props {
  title: string;
  description?: string;
  lang?: string;
}
const { title, description = 'Config Wiki — AI, LLM, VLA, Robotics', lang = 'ko' } = Astro.props;
const base = (import.meta.env.BASE_URL || '/').replace(/\/$/, '') || '';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (function () {
        var THEME_KEY = 'wiki-theme';

        function readStoredMode() {
          try {
            var t = localStorage.getItem(THEME_KEY);
            if (t === 'light' || t === 'dark' || t === 'system') return t;
          } catch (e) {}
          return null;
        }

        function resolvedFromMode(mode) {
          if (mode === 'light' || mode === 'dark') return mode;
          return fromMq();
        }

        function applyResolved(resolved, origin) {
          if (resolved === 'light') document.documentElement.setAttribute('data-theme', 'light');
          else document.documentElement.removeAttribute('data-theme');
          try {
            window.dispatchEvent(
              new CustomEvent('wiki-theme-changed', {
                detail: { resolved: resolved, mode: readStoredMode(), origin: origin || 'init' },
              }),
            );
          } catch (_) {}
        }

        var mq = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)');
        var fromMq = function () {
          return mq && mq.matches ? 'dark' : 'light';
        };

        var storedMode = readStoredMode();
        applyResolved(resolvedFromMode(storedMode), storedMode ? 'storage' : 'system');

        if (mq) {
          var onOsChange = function () {
            var m = readStoredMode();
            if (m === 'light' || m === 'dark') return;
            applyResolved(fromMq(), 'system');
          };
          if (mq.addEventListener) mq.addEventListener('change', onOsChange);
          else if (mq.addListener) mq.addListener(onOsChange);
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={`${base}/images/config-logo.png`} sizes="32x32" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
      integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV"
      crossOrigin="anonymous"
    />
    <title>{title} | Config Wiki</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --bg: #0f0f12;
    --surface: #18181c;
    --border: #2a2a30;
    --text: #e4e4e7;
    --muted: #a1a1aa;
    --accent: rgb(51, 123, 250);
    --accent-hover: rgb(0, 45, 203);
    --on-accent: #ffffff;
    --shadow-dropdown: 0 8px 24px rgba(0, 0, 0, 0.25);
    --shadow-popover: 0 4px 12px rgba(0, 0, 0, 0.15);
    --shadow-drawer: -4px 0 24px rgba(0, 0, 0, 0.3);
    --overlay-backdrop: rgba(0, 0, 0, 0.5);
    --input-bg: rgba(255, 255, 255, 0.055);
    --media-chrome-bg: #0b1220;
    --social-btn-bg: rgba(15, 23, 42, 0.9);
    --social-btn-fg: #e5e7eb;
    --social-btn-shadow: 0 8px 20px rgba(15, 23, 42, 0.35);
    --fab-bg: rgba(51, 123, 250, 0.95);
    --fab-bg-hover: rgba(0, 45, 203, 0.98);
    --fab-color: #ffffff;
    --fab-shadow: 0 10px 25px rgba(51, 123, 250, 0.35), 0 0 0 1px rgba(51, 123, 250, 0.55);
    --tag-tint: rgba(51, 123, 250, 0.06);
  }
  html[data-theme='light'] {
    color-scheme: light;
    --bg: #f4f4f5;
    --surface: #ffffff;
    --border: #e4e4e7;
    --text: #18181b;
    --muted: #71717a;
    --accent: rgb(37, 99, 235);
    --accent-hover: rgb(29, 78, 216);
    --on-accent: #ffffff;
    --shadow-dropdown: 0 8px 24px rgba(0, 0, 0, 0.08);
    --shadow-popover: 0 4px 12px rgba(0, 0, 0, 0.06);
    --shadow-drawer: -4px 0 24px rgba(0, 0, 0, 0.1);
    --overlay-backdrop: rgba(0, 0, 0, 0.25);
    --input-bg: rgba(0, 0, 0, 0.04);
    --media-chrome-bg: #e8e8ec;
    --social-btn-bg: rgba(228, 228, 231, 0.95);
    --social-btn-fg: #27272a;
    --social-btn-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
    --fab-bg: rgba(37, 99, 235, 0.92);
    --fab-bg-hover: rgba(29, 78, 216, 0.98);
    --fab-color: #ffffff;
    --fab-shadow: 0 10px 25px rgba(37, 99, 235, 0.28), 0 0 0 1px rgba(37, 99, 235, 0.4);
    --tag-tint: rgba(37, 99, 235, 0.08);
  }
  html {
    font-family: system-ui, 'Segoe UI', sans-serif;
    background: var(--bg);
    color: var(--text);
  }
  body { margin: 0; min-height: 100vh; line-height: 1.6; }
  a { color: var(--accent); text-decoration: none; }
  a:hover { color: var(--accent-hover); text-decoration: underline; }
  .wiki-article .katex { color: var(--text); }
</style>
