---
import type { Locale } from '../data/i18n';
import { getWikiNav } from '../data/wikiNav';

interface Props {
  currentPath: string;
  locale?: Locale;
}
const { currentPath, locale = 'en' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
const wikiNav = getWikiNav(locale, base);

function isActive(href: string): boolean {
  const path = currentPath.replace(base, '') || '/';
  const linkPath = href.replace(base, '');
  const pathNorm = path.replace(/\/$/, '') || '/';
  const linkNorm = linkPath.replace(/\/$/, '') || '/';
  if (linkNorm === `/${locale}` || linkNorm === '/') {
    return pathNorm === `/${locale}` || pathNorm === '/';
  }
  return path === linkPath || path.startsWith(linkPath);
}
---

<aside class="sidebar">
  <nav>
    {wikiNav.map((item) =>
      item.children ? (
        <div class="nav-group">
          <span class="nav-group-title">{item.label}</span>
          {item.children.map((child) => (
            <a href={child.href} class:list={['nav-item', 'nav-child', { 'is-active': isActive(child.href ?? '') }]}>{child.label}</a>
          ))}
        </div>
      ) : (
        <a href={item.href} class:list={['nav-item', { 'is-active': isActive(item.href ?? '') }]}>{item.label}</a>
      ),
    )}
  </nav>
</aside>

<style>
  .sidebar {
    width: var(--wiki-sidebar-w, 192px);
    box-sizing: border-box;
    flex-shrink: 0;
    padding: 0.65rem 0.5rem;
    background: var(--surface);
    overflow-y: auto;
  }
  nav {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .nav-item {
    padding: 0.3rem 0.4rem;
    border-radius: 4px;
    color: var(--muted);
    font-size: 0.82rem;
    display: block;
  }
  .nav-item:hover { color: var(--accent); background: rgba(51, 123, 250, 0.1); }
  .nav-section-title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
    margin-bottom: 0.25rem;
    padding-left: 0.5rem;
  }
  .nav-group-title {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
    margin-top: 0.5rem;
    margin-bottom: 0.15rem;
    padding-left: 0.4rem;
  }
  .nav-child { padding-left: 0.75rem !important; }
  .nav-item.is-active { color: var(--accent); font-weight: 500; background: rgba(51, 123, 250, 0.12); }
  @media (max-width: 768px) {
    .sidebar { width: 100%; min-height: auto; border-right: none; border-bottom: 1px solid var(--border); }
  }
</style>
