---
import WikiLayout from '../../../layouts/WikiLayout.astro';
import { i18n } from '../../../data/i18n';
import type { Locale } from '../../../data/i18n';

export async function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'ko' } }];
}

const { locale } = Astro.params as { locale: Locale };
const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
const t = i18n[locale] ?? i18n.en;
---

<WikiLayout title={t.about.title} locale={locale}>
  <article class="about-page">
    <div class="about-header">
      <img src={`${base}/images/tony-lee.png`} alt="Tony Lee" class="about-photo" width="160" height="160" />
      <div class="about-intro">
        <h1>Tony Lee</h1>
        <p class="about-role">{t.about.role}</p>
      </div>
    </div>

    <section class="about-section">
      <h2>{t.about.education}</h2>
      <p><strong>UC Berkeley</strong> — B.S. Chemical Engineering</p>
    </section>

    <section class="about-section">
      <h2>{t.about.experience}</h2>
      <ul>
        <li><strong>Config Intelligence Inc.</strong> — Head of Product (from Apr 2026). Data infrastructure & foundation models for general-purpose bimanual robotics.</li>
        <li><strong>Toss</strong> — Product Owner (current until Apr 2026).</li>
        <li><strong>Tridge</strong> — Product Manager.</li>
        <li><strong>Lineable</strong> — Product Manager.</li>
      </ul>
    </section>

    <section class="about-section">
      <h2>{t.about.focus}</h2>
      <p>AI, LLM, VLA, robotics—learning and tracking industry research. Using this wiki to organize company knowledge, domains, and news; and Claude/Claude Code for workflow automation.</p>
    </section>
  </article>
</WikiLayout>

<style>
  .about-page { max-width: 640px; padding: 0 1rem 3rem; }
  .about-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .about-photo {
    width: 160px;
    height: 160px;
    object-fit: cover;
    object-position: top;
    border-radius: 12px;
    flex-shrink: 0;
  }
  .about-intro h1 { font-size: 1.75rem; margin: 0 0 0.5rem 0; }
  .about-role { color: var(--muted); margin: 0; font-size: 1rem; }
  .about-section { margin-top: 1.5rem; }
  .about-section h2 { font-size: 1.1rem; margin-bottom: 0.5rem; color: var(--muted); border-bottom: 1px solid var(--border); padding-bottom: 0.25rem; }
  .about-section ul { margin: 0.5rem 0 0; padding-left: 1.25rem; }
  .about-section li { margin-bottom: 0.5rem; line-height: 1.5; }
</style>
