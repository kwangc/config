---
import WikiLayout from '../../../layouts/WikiLayout.astro';
import newsData from '../../../data/news.json';
import { i18n } from '../../../data/i18n';
import type { Locale } from '../../../data/i18n';

const PAGE_SIZE = 10;

type NewsItem = {
  id: string;
  title: string;
  url: string;
  summary?: string;
  summaryKo?: string;
  date: string;
  source?: string;
  tags?: string[];
  recaps?: {
    twitter?: { bulletsKo?: string[]; bulletsEn?: string[]; summaryKo?: string; summaryEn?: string };
    reddit?: { bulletsKo?: string[]; bulletsEn?: string[]; summaryKo?: string; summaryEn?: string };
    discord?: { bulletsKo?: string[]; bulletsEn?: string[]; summaryKo?: string; summaryEn?: string };
  };
};

export async function getStaticPaths() {
  const PAGE_SIZE = 10;
  const items = (newsData as { items: NewsItem[] }).items;
  const sorted = [...items].sort((a, b) => (b.date || '').localeCompare(a.date || ''));
  const totalPages = Math.ceil(sorted.length / PAGE_SIZE);
  const paths = [];
  for (const locale of ['en', 'ko'] as Locale[]) {
    for (let page = 2; page <= totalPages; page++) {
      paths.push({
        params: { locale, page: String(page) },
        props: {
          pageItems: sorted.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE),
          totalPages,
          currentPage: page,
          totalItems: sorted.length,
        },
      });
    }
  }
  return paths;
}

const { locale, page: pageParam } = Astro.params as { locale: Locale; page: string };
const { pageItems, totalPages, currentPage, totalItems } = Astro.props as {
  pageItems: NewsItem[];
  totalPages: number;
  currentPage: number;
  totalItems: number;
};

const t = i18n[locale] ?? i18n.en;
const base = (import.meta.env.BASE_URL || '/').replace(/\/$/, '') || '';

const labels =
  locale === 'ko'
    ? { twitter: '트위터 요약', reddit: '레딧 요약', discord: '디스코드 요약' }
    : { twitter: 'Twitter recap', reddit: 'Reddit recap', discord: 'Discord recap' };

function toBullets(val: unknown) {
  if (Array.isArray(val)) return val.map((x) => String(x).trim()).filter(Boolean);
  if (typeof val === 'string') {
    return val.split('\n').map((x) => x.trim()).filter(Boolean)
      .map((line) => line.replace(/^([-•]|\d+\.)\s+/, ''));
  }
  return [];
}

function getSectionBullets(item: NewsItem, section: 'twitter' | 'reddit' | 'discord') {
  const recap = item.recaps?.[section];
  if (!recap) return [];
  if (locale === 'ko') return toBullets(recap.bulletsKo ?? recap.summaryKo);
  return toBullets(recap.bulletsEn ?? recap.summaryEn ?? recap.summaryKo);
}

const prevHref = currentPage === 2
  ? `${base}/${locale}/news/`
  : `${base}/${locale}/news/${currentPage - 1}/`;
const nextHref = currentPage < totalPages
  ? `${base}/${locale}/news/${currentPage + 1}/`
  : null;
---

<WikiLayout title={`${t.news.title} — ${locale === 'ko' ? `${currentPage}페이지` : `Page ${currentPage}`}`} locale={locale}>
  <article class="news-page">
    <h1>{t.news.title}</h1>
    <p class="lead">{t.news.lead}</p>
    <ul class="news-list" aria-label="News list">
      {pageItems.map((item) => {
        const twitterBullets = getSectionBullets(item, 'twitter');
        const redditBullets = getSectionBullets(item, 'reddit');
        const discordBullets = getSectionBullets(item, 'discord');
        const fallbackSummary =
          locale === 'ko' ? item.summaryKo ?? item.summary ?? '' : item.summary ?? item.summaryKo ?? '';
        const fallbackBullets = toBullets(fallbackSummary);
        return (
          <li class="news-item">
            <details class="news-card">
              <summary class="news-card-summary">
                <span class="news-card-summary-left">
                  <span class="news-card-date">{item.date}</span>
                  <a href={item.url} target="_blank" rel="noopener noreferrer" class="news-card-title">
                    {item.title}
                  </a>
                </span>
                <span class="news-card-arrow" aria-hidden="true">▸</span>
              </summary>
              <div class="news-card-body">
                {twitterBullets.length ? (
                  <section class="news-section">
                    <h2 class="news-section-title">{labels.twitter}</h2>
                    <ul class="news-section-bullets">
                      {twitterBullets.map((b, idx) => (
                        <li key={`tw-${idx}`}><a class="news-bullet-link" href={item.url} target="_blank" rel="noopener noreferrer">{b}</a></li>
                      ))}
                    </ul>
                  </section>
                ) : null}
                {redditBullets.length ? (
                  <section class="news-section">
                    <h2 class="news-section-title">{labels.reddit}</h2>
                    <ul class="news-section-bullets">
                      {redditBullets.map((b, idx) => (
                        <li key={`rd-${idx}`}><a class="news-bullet-link" href={item.url} target="_blank" rel="noopener noreferrer">{b}</a></li>
                      ))}
                    </ul>
                  </section>
                ) : null}
                {discordBullets.length ? (
                  <section class="news-section">
                    <h2 class="news-section-title">{labels.discord}</h2>
                    <ul class="news-section-bullets">
                      {discordBullets.map((b, idx) => (
                        <li key={`dc-${idx}`}><a class="news-bullet-link" href={item.url} target="_blank" rel="noopener noreferrer">{b}</a></li>
                      ))}
                    </ul>
                  </section>
                ) : null}
                {twitterBullets.length || redditBullets.length || discordBullets.length ? null : (
                  <section class="news-section">
                    <h2 class="news-section-title">{locale === 'ko' ? '요약' : 'Summary'}</h2>
                    {fallbackBullets.length ? (
                      <ul class="news-section-bullets">
                        {fallbackBullets.map((b, idx) => (
                          <li key={`fb-${idx}`}><a class="news-bullet-link" href={item.url} target="_blank" rel="noopener noreferrer">{b}</a></li>
                        ))}
                      </ul>
                    ) : (
                      <p class="news-section-summary">{fallbackSummary}</p>
                    )}
                  </section>
                )}
                {item.source || item.tags?.length ? (
                  <div class="news-meta">
                    {item.source && <span class="source">{item.source}</span>}
                    {item.tags?.length ? <span class="tags">{item.tags.join(', ')}</span> : null}
                  </div>
                ) : null}
              </div>
            </details>
          </li>
        );
      })}
    </ul>
    <nav class="news-pagination" aria-label="Pagination">
      <span class="news-pagination-info">
        {locale === 'ko'
          ? `${currentPage} / ${totalPages} 페이지 · 총 ${totalItems}개`
          : `Page ${currentPage} of ${totalPages} · ${totalItems} items`}
      </span>
      <div class="news-pagination-controls">
        <a href={prevHref} class="news-pagination-btn">
          ← {locale === 'ko' ? '이전' : 'Prev'}
        </a>
        {nextHref ? (
          <a href={nextHref} class="news-pagination-btn">
            {locale === 'ko' ? '다음' : 'Next'} →
          </a>
        ) : (
          <span class="news-pagination-btn news-pagination-btn--disabled" aria-disabled="true">
            {locale === 'ko' ? '다음' : 'Next'} →
          </span>
        )}
      </div>
    </nav>
  </article>
</WikiLayout>

<style>
  .news-page { max-width: 720px; padding: 0 1rem 3rem; }
  .lead { color: var(--muted); margin-bottom: 1.5rem; }
  .lead code { font-size: 0.85em; }
  .news-list { list-style: none; padding: 0; margin: 0; }
  .news-item {
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--border);
  }
  .news-item:last-child { border-bottom: none; }
  .news-card {
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    background: var(--surface);
    padding: 0.85rem 0.85rem;
  }
  .news-card-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .news-card-summary::-webkit-details-marker { display: none; }
  .news-card-summary-left {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .news-card-date { font-size: 0.85rem; color: var(--muted); }
  .news-card-title {
    font-weight: 650;
    font-size: 1.05rem;
    color: inherit;
    text-decoration: none;
  }
  .news-card-title:hover { text-decoration: underline; }
  .news-card-arrow {
    font-size: 1rem;
    color: var(--muted);
    transition: transform 160ms ease;
  }
  .news-card[open] .news-card-arrow { transform: rotate(90deg); }
  .news-card-body { margin-top: 0.75rem; }
  .news-section { margin-top: 0.9rem; }
  .news-section:first-child { margin-top: 0; }
  .news-section-title {
    font-weight: 650;
    font-size: 0.95rem;
    margin: 0 0 0.25rem 0;
  }
  .news-section-summary {
    color: var(--muted);
    font-size: 0.95rem;
    margin: 0;
    line-height: 1.55;
    white-space: pre-wrap;
  }
  .news-section-bullets {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .news-section-bullets li { margin: 0.25rem 0; }
  .news-bullet-link { color: inherit; text-decoration: none; }
  .news-bullet-link:hover { text-decoration: underline; }
  .news-meta { font-size: 0.8rem; color: var(--muted); margin-top: 0.6rem; }
  .news-meta .source, .news-meta .tags { margin-left: 0.75rem; }

  .news-pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }
  .news-pagination-info {
    font-size: 0.85rem;
    color: var(--muted);
  }
  .news-pagination-controls {
    display: flex;
    gap: 0.5rem;
  }
  .news-pagination-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.85rem;
    border-radius: 6px;
    font-size: 0.85rem;
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    background: var(--surface);
    transition: background 0.12s, color 0.12s;
  }
  .news-pagination-btn:hover {
    background: rgba(51, 123, 250, 0.1);
    color: var(--accent);
    text-decoration: none;
  }
  .news-pagination-btn--disabled {
    opacity: 0.35;
    cursor: default;
    pointer-events: none;
  }
</style>
